{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VaultKern",
  "version": "0.1.0",
  "identifier": "com.vaultkern.windows",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VaultKern",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 560,
        "center": true,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}
