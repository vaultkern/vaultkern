{
  "manifest_version": 3,
  "name": "VaultKern Browser",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "nativeMessaging",
    "activeTab",
    "scripting",
    "webAuthenticationProxy"
  ],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ]
}
